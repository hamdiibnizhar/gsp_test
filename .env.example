RAG_CHUNK_SIZE=120
RAG_CHUNK_OVERLAP=30
RAG_EMBED_DIM=384
RAG_CONFIDENCE_THRESHOLD=0.15
#VPN
OLLAMA_BASE_URL=http://10.30.50.2:11434
#local
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT_SECONDS=20
RAG_STORAGE_DIR=/app/data
PGVECTOR_DSN=postgresql://gsp:gsp@postgres:5432/gsp
PGVECTOR_TABLE=rag_chunks
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
REDIS_CACHE_PREFIX=gsp:query-cache
REDIS_CACHE_TTL_SECONDS=0
OCR_ENABLED=true
OCR_MIN_TEXT_CHARS=80
OCR_DPI=200
OCR_LANG=eng
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_INGEST_TOPIC=rag.document.ingest
KAFKA_RETRY_TOPIC=rag.document.ingest.retry
KAFKA_DLQ_TOPIC=rag.document.ingest.dlq
KAFKA_GROUP_ID=rag-ingester
WATCH_DIRECTORY=/app/incoming_docs
PROCESSED_DIRECTORY=/app/processed_docs
FAILED_DIRECTORY=/app/failed_docs
WATCHER_POLL_SECONDS=2
WATCHER_STABLE_SECONDS=3
INGEST_MAX_RETRIES=3
